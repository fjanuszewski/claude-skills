{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "sst.config.ts",
    "infra/**/*.ts",
    ".sst/platform/config.d.ts"
  ],
  "exclude": [
    "node_modules",
    "packages"
  ]
}
